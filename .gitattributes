# Auto-normalize line endings to LF on commit
* text=auto eol=lf

# Texto: siempre LF
*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.xml   text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.svg   text eol=lf
*.webmanifest text eol=lf

# Binarios
*.png   binary
*.jpg   binary
*.jpeg  binary
*.webp  binary
*.avif  binary
*.ico   binary
*.woff2 binary
*.pdf   binary
